# Database connection (same Postgres instance as backend service)
DATABASE_URL=postgresql://user:password@localhost:5432/project_k

# Analytics schema name (created by alembic migrations)
ANALYTICS_SCHEMA=analytics

# Logging
LOG_LEVEL=INFO
SQL_ECHO=false

# API server
API_HOST=0.0.0.0
API_PORT=8001

# Config directory
CONFIG_DIR=config
